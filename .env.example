# Copy this file to .env and fill in your own values.
# Required for local `sanity dev` / `sanity deploy` / `sanity undeploy`.

SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# Only needed for non-interactive deploys/undeploys (e.g. in CI).
# Create a deploy token at https://sanity.io/manage
SANITY_AUTH_TOKEN=
